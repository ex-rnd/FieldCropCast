# WeatherAI API key — get yours at https://weather-ai.co/dashboard
WAI_API_KEY=wai_your_key_here

# Port to run the server on (optional, defaults to 3000)
PORT=3000

# Optional: secret token WeatherAI sends with webhook POSTs.
# If set, the webhook endpoint validates x-webhook-secret header or ?secret= query param.
# Leave blank to accept all incoming webhooks without authentication.
WEBHOOK_SECRET=

# Optional: public base URL of this deployment — used to render the webhook URL in the UI.
# Falls back to window.location.origin in the browser if not set.
NEXT_PUBLIC_APP_URL=http://localhost:3000
